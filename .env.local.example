# ─── SpacedOut Environment Variables ───

# NASA API Key (REQUIRED)
# Get yours free at: https://api.nasa.gov/
# DEMO_KEY works but is limited to 30 req/hr and 50 req/day
NASA_API_KEY=DEMO_KEY

# ─── No API keys needed for the following ───
# Launch Library 2  — Free, no key (15 req/hr)
# Open Notify       — Free, no key
# Where The ISS At  — Free, no key
# SpaceX API        — Free, no key
# Spaceflight News  — Free, no key
